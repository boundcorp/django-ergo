# Django Ergo Environment Variables Example
# Copy this file to .env and fill in your actual values

# Database Configuration
DB_NAME=your_database_name
DB_USER=your_database_user
DB_PASSWORD=your_database_password
DB_HOST=localhost
DB_PORT=5432
TEST_DB_NAME=test_your_database_name

# OpenAI Configuration (required for AI features)
OPENAI_API_KEY=sk-your-openai-api-key-here

# Django Secret Key (generate a new one for production)
# You can generate one with: python -c 'from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())'
SECRET_KEY=your-secret-key-here

# Optional: Override default OpenAI settings
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_TEMPERATURE=0.7
# OPENAI_TIMEOUT=30

# Optional: Embedding provider settings
# EMBEDDING_MODEL=text-embedding-3-small
